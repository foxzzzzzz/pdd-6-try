# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Database (SQLite path relative to project root)
DATABASE_PATH=./data/pdd-inspector.db

# AI Provider (claude | openai | deepseek | local)
AI_PROVIDER=claude
AI_LIGHT_MODEL=claude-haiku-4-5
AI_HEAVY_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
DEEPSEEK_API_KEY=sk-xxx

# Server
PORT=3000
HOST=0.0.0.0

# Worker
WORKER_CONCURRENCY=3
WORKER_HEADLESS=false
WORKER_SECURITY_CHALLENGE_WAIT_MS=180000
WORKER_READ_FIRST_PAGE_DELAY_MS=3000-6000
WORKER_READ_NAV_BEFORE_DELAY_MS=1000-2500
WORKER_READ_NAV_AFTER_DELAY_MS=2500-5500
WORKER_READ_MODULE_GAP_MS=1500-4000
WORKER_ENABLE_APPEAL_METRICS=false

# Browser
BROWSER_DISABLE_SANDBOX=false
